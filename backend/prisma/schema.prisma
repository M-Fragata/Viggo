generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  role            Role      @default(USER) // ADMIN ou USER
  
  // Biometria: Onde guardaremos o vetor numérico do rosto
  // Usamos Json pois o descritor é um array de números (Float32Array)
  faceDescriptor  Json?     

  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  
  checkIns        CheckIn[]
  createdAt       DateTime  @default(now())
}

model CheckIn {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  latitude   Float?
  longitude  Float?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
}
